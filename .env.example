# Urls prefix [useful to change between HTTPS/WSS/Backend Version]
DEBUG_MODE=true
NEXT_PUBLIC_HTTP_PROTOCOLE=http
HTTP=http://
WS=ws://
# CORS - Allowed origins for API requests (comma-separated)
ALLOWED_ORIGINS=localhost:3003
# next js backend api (for cookies)
NEXT_PUBLIC_BACKEND_DOMAIN=localhost:3003
NEXT_PUBLIC_BACKEND_API="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}/api"
NEXT_PUBLIC_API_ROOT_URL=localhost
NEXT_PUBLIC_API_ROOT_PORT=8002
NEXT_PUBLIC_API_URL="${HTTP}${NEXT_PUBLIC_API_ROOT_URL}:${NEXT_PUBLIC_API_ROOT_PORT}"
# Base urls
NEXT_PUBLIC_ROOT_API_URL="${HTTP}${NEXT_PUBLIC_API_ROOT_URL}:${NEXT_PUBLIC_API_ROOT_PORT}/api"
NEXT_PUBLIC_ROOT_WS_URL="${WS}${NEXT_PUBLIC_API_ROOT_URL}:${NEXT_PUBLIC_API_ROOT_PORT}/ws"
NEXT_PUBLIC_WS_MAINTENANCE_ROOT=/ws/maintenance/
# to remove in production
AUTH_TRUST_HOST=true
NEXTAUTH_SECRET=authSecretKey
NEXTAUTH_URL="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}"
NEXT_PUBLIC_DOMAIN_URL_PREFIX="${HTTP}${NEXT_PUBLIC_BACKEND_DOMAIN}"
# Account
NEXT_PUBLIC_ACCOUNT_ROOT=/account
NEXT_PUBLIC_ACCOUNT_REFRESH_TOKEN=$NEXT_PUBLIC_ACCOUNT_ROOT/token_refresh/
NEXT_PUBLIC_ACCOUNT_LOGIN=$NEXT_PUBLIC_ACCOUNT_ROOT/login/
NEXT_PUBLIC_ACCOUNT_LOGOUT=$NEXT_PUBLIC_ACCOUNT_ROOT/logout/
NEXT_PUBLIC_ACCOUNT_CREATE_ACCOUNT=$NEXT_PUBLIC_ACCOUNT_ROOT/create_account/
NEXT_PUBLIC_ACCOUNT_CHECK_EMAIL=$NEXT_PUBLIC_ACCOUNT_ROOT/check_email/
NEXT_PUBLIC_ACCOUNT_PASSWORD_CHANGE=$NEXT_PUBLIC_ACCOUNT_ROOT/password_change/
NEXT_PUBLIC_ACCOUNT_SEND_PASSWORD_RESET=$NEXT_PUBLIC_ACCOUNT_ROOT/send_password_reset/
NEXT_PUBLIC_ACCOUNT_PASSWORD_RESET=$NEXT_PUBLIC_ACCOUNT_ROOT/password_reset/
NEXT_PUBLIC_ACCOUNT_PROFIL=$NEXT_PUBLIC_ACCOUNT_ROOT/profil/
NEXT_PUBLIC_USERS_ROOT=$NEXT_PUBLIC_ACCOUNT_ROOT/users/
# Project Management
NEXT_PUBLIC_PROJECT_ROOT=/project
NEXT_PUBLIC_PROJECT_LIST=$NEXT_PUBLIC_PROJECT_ROOT/
NEXT_PUBLIC_PROJECT_CATEGORIES=$NEXT_PUBLIC_PROJECT_ROOT/categories/
NEXT_PUBLIC_PROJECT_SUBCATEGORIES=$NEXT_PUBLIC_PROJECT_ROOT/subcategories/
NEXT_PUBLIC_PROJECT_EXPENSE_TAXONOMY=$NEXT_PUBLIC_PROJECT_ROOT/expense-taxonomy/
# Revenue
NEXT_PUBLIC_REVENUE_LIST=/revenu/
# Expense
NEXT_PUBLIC_EXPENSE_LIST=/depense/
# Notifications
NEXT_PUBLIC_PROJET_NOTIFICATION_ROOT=/notifications
NEXT_PUBLIC_PROJET_NOTIFICATIONS=$NEXT_PUBLIC_PROJET_NOTIFICATION_ROOT/
NEXT_PUBLIC_PROJET_NOTIFICATION_PREFERENCES=$NEXT_PUBLIC_PROJET_NOTIFICATION_ROOT/preferences/
NEXT_PUBLIC_PROJET_NOTIFICATION_MARK_READ=$NEXT_PUBLIC_PROJET_NOTIFICATION_ROOT/mark-read/
NEXT_PUBLIC_PROJET_NOTIFICATION_UNREAD_COUNT=$NEXT_PUBLIC_PROJET_NOTIFICATION_ROOT/unread-count/